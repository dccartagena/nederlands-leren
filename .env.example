# Copy to .env and fill in values
DATABASE_URL=sqlite:////path/to/data/app.db    # or postgresql://...
LLM_PROVIDER=ollama                            # ollama | openai | anthropic | mistral | gemini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
REMOTE_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini/gemini-2.0-flash
PIXABAY_API_KEY=
DEBUG=false
SECRET_KEY=change-me-in-production

# Background automation (in-process scheduler)
SCHEDULER_ENABLED=true
AUTO_SEED=true
AUTO_BACKUP=true
AUTO_AUDIO_GAPFILL=true
AUTO_FSRS_OPTIMIZE=true
AUTO_CONTENT_REFRESH=false   # weekly ETL refresh; large downloads — enable deliberately
BACKUP_RETENTION=14
AUDIO_GAPFILL_BATCH=50
SCHEDULER_TICK_SECONDS=1800

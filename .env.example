# Copy to .env and fill in values
DATABASE_URL=sqlite:////path/to/data/app.db    # or postgresql://...
LLM_PROVIDER=ollama                            # ollama | openai | anthropic | mistral | gemini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M
# TTS — Voxtral (Ollama) is the primary engine; gTTS is the internet-based fallback
TTS_PROVIDER=voxtral                           # voxtral | gtts
OLLAMA_TTS_MODEL=hf.co/bartowski/Voxtral-4B-TTS-2603-GGUF:Q4_K_M
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
REMOTE_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini/gemini-2.0-flash
PIXABAY_API_KEY=
DEBUG=false
SECRET_KEY=change-me-in-production

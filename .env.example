# Copy to .env and fill in values
DATABASE_URL=sqlite:////path/to/data/app.db    # or postgresql://...
LLM_PROVIDER=ollama                            # ollama | openai | anthropic | mistral | gemini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
REMOTE_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini/gemini-2.0-flash
PIXABAY_API_KEY=
DEBUG=false
SECRET_KEY=change-me-in-production

# CORS — comma-separated list of allowed frontend origins.
# Add your Tailscale HTTPS hostname so the PWA can reach the API from mobile.
# Example: CORS_ORIGINS=http://localhost:5173,http://localhost,https://mymachine.tail1234.ts.net
CORS_ORIGINS=http://localhost:5173,http://localhost
